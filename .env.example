# ─────────────────────────────────────────────────────────────────────────
# Go Cold WMS — single .env for the whole NUC stack.
#
# Copy to .env (gitignored), fill in real values. docker-compose.yml loads it
# into every service via `env_file`. The two Python consoles ALSO bind-mount
# this file read-only at /app/.env (and scripts/smoke_test.py / extract.py read
# it directly). NEVER commit real values; NEVER bake them into an image.
#
# NOTE: the DB password is NOT here — it lives in ./secrets/db_password.txt
# (Docker secret) and DATABASE_URL is assembled from it at run time.
# ─────────────────────────────────────────────────────────────────────────

# ===== CartonCloud — Python consoles (picks + runs) ======================
# OAuth2 client_credentials. Create in CC: Admin → API Clients → Create.
# Read-only roles required: "WMS Create Job" (orders + SOH) and
# "WMS Add/Edit Product" (warehouse products).
CC_CLIENT_ID=your_cc_client_id
CC_CLIENT_SECRET=your_cc_client_secret

# Tenant UUID (shared by both stacks). Run scripts/smoke_test.py if unsure.
CC_TENANT_ID=your_cc_tenant_uuid

# Keep the read-only client read-only. Only ever 'true' for an explicitly
# approved write flow (off by default; the client refuses writes otherwise).
CC_WRITE_ENABLED=false

# Optional log level: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# DO NOT set CC_BASE_URL here. The consoles (https://api.cartoncloud.com) and
# the dim-capture backend (https://app.cartoncloud.com.au/api/v1) need
# DIFFERENT bases; each is pinned per-service in docker-compose.yml. Setting it
# here would poison one of them.

# ===== CartonCloud — dim-capture backend (dims) ==========================
# Bearer-token auth model (separate from the OAuth client above).
CC_API_KEY=your_cc_api_key
CC_WAREHOUSE_ID=your_cc_warehouse_uuid

# Enables the CC sync (POST /api/sync/cc) and seed (POST /api/admin/seed)
# routes. If unset, BOTH fail-closed with 503 (never an unauthenticated CC
# write). Generate a strong value:  openssl rand -hex 32
SYNC_SECRET=
