# Copy this file to .env (which is gitignored) and fill in real values.
# .env is loaded automatically by scripts/smoke_test.py and scripts/extract.py.

# CartonCloud API client credentials.
# Generate in CC: Admin → API Clients → Create new client.
# Required roles for read-only extraction:
#   - WMS Create Job        (for inbound/outbound order search + SOH report)
#   - WMS Add/Edit Product  (for warehouse product search)
CC_CLIENT_ID=
CC_CLIENT_SECRET=

# Tenant UUID. After creating credentials, run scripts/smoke_test.py and
# it will print accessible tenants if this is wrong.
CC_TENANT_ID=

# Optional. Defaults to global https://api.cartoncloud.com.
# Use https://api.na.cartoncloud.com for the North America region.
# CC_BASE_URL=https://api.cartoncloud.com

# Set to 'true' ONLY when you intentionally want to enable POST/PUT/PATCH/DELETE.
# Default false; client refuses writes silently otherwise.
# CC_WRITE_ENABLED=false

# Optional logging level: DEBUG / INFO / WARNING / ERROR
# LOG_LEVEL=INFO
